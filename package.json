{
  "name" : "monorepo-root",
  "version" :"1.0.0",
  "private" : true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prisma:generate": "npm run prisma:generate -w backend",
    "prisma:studio": "npm run prisma:studio -w backend",
    "prisma:migrate": "npm run prisma:migrate -w backend",
    "prisma:push": "npm run prisma:push -w backend",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:all": "npm run dev:backend & npm run dev:frontend"
  }
}